
ACTION=="add|remove", SUBSYSTEM=="block", DEVPATH=="*/ff520000.mmc/mmc_host/mmc1/mmc1:0001/block/mmcblk1/mmcblk1boot1",  RUN+="/usr/lib/unipi/uhelper '' nvmem 1 $name"
ACTION=="add|remove", SUBSYSTEM=="block", DEVPATH=="*/ff520000.mmc/mmc_host/mmc1/mmc1:0001/block/mmcblk1/mmcblk1gp0",  RUN+="/usr/lib/unipi/uhelper '' gpp 1 $name"
